# ═══════════════════════════════════════════════════
#  ResearchIQ — Environment Variables
#  Copy: cp .env.example .env
#  Never commit .env to git
# ═══════════════════════════════════════════════════

# Application
APP_ENV=development
APP_NAME=ResearchIQ
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=researchiq
POSTGRES_USER=researchiq
POSTGRES_PASSWORD=researchiq_dev_password
DATABASE_URL=postgresql+asyncpg://researchiq:researchiq_dev_password@localhost:5432/researchiq

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PAPERS=papers
QDRANT_COLLECTION_PATENTS=patents

# LLM Providers
# Get yours at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional fallback
OPENAI_API_KEY=sk-your-key-here
# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=

# External Data APIs
# Free: semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Free: ncbi.nlm.nih.gov/account
NCBI_API_KEY=
# Free tier: serpapi.com
SERPAPI_KEY=
# No key needed — just email for CrossRef polite pool
CROSSREF_EMAIL=you@example.com

# Auth
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Feature Flags
# true = use fixture data, no API keys needed
MOCK_INGESTION=true
MOCK_LLM=false
ENABLE_FUNDING_MODULE=false
